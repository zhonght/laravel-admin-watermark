{
    "name": "zhonght/laravel-admin-watermark",
    "description": "Watermark extension for laravel-admin",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=7.1",
        "encore/laravel-admin": "~1.7"
    },
    "autoload": {
        "psr-4": {
            "Zhonght\\AdminWatermark\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zhonght\\AdminWatermark\\WatermarkServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
